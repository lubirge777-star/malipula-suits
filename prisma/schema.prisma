// Malipula Suits Platform - Database Schema
// Royal. Rooted. Refined.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ============================================
// USER MANAGEMENT
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  phone         String?
  name          String?
  password      String?
  image         String?
  role          UserRole  @default(CUSTOMER)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  measurements  Measurement[]
  addresses     Address[]
  orders        Order[]
  appointments  Appointment[]
  reviews       Review[]
  wishlist      Wishlist[]
  cartItems     CartItem[]

  @@map("users")
}

enum UserRole {
  CUSTOMER
  ADMIN
  TAILOR
  STYLIST
}

model Address {
  id          String   @id @default(cuid())
  userId      String
  label       String?  // Home, Work, etc.
  street      String
  city        String
  region      String?
  country     String   @default("Tanzania")
  postalCode  String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

// ============================================
// MEASUREMENTS
// ============================================

model Measurement {
  id              String   @id @default(cuid())
  userId          String
  profileName     String   @default("Default")
  isDefault       Boolean  @default(false)
  
  // Upper Body
  neck            Float?
  shoulders       Float?
  chest           Float?
  waist           Float?
  sleeveLength    Float?
  wrist           Float?
  backLength      Float?
  
  // Lower Body
  hip             Float?
  thigh           Float?
  knee            Float?
  calf            Float?
  ankle           Float?
  inseam          Float?
  outseam         Float?
  
  // Full Body
  height          Float?
  weight          Float?
  
  // Fit Preference
  fitPreference   FitType  @default(REGULAR)
  notes           String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("measurements")
}

enum FitType {
  SLIM
  REGULAR
  RELAXED
}

// ============================================
// PRODUCTS & INVENTORY
// ============================================

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  image       String?
  parentId    String?
  order       Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]

  @@map("categories")
}

model Fabric {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  description   String?
  material      String?       // Wool, Cotton, Linen, etc.
  composition   String?       // 100% Wool, etc.
  weight        String?       // GSM
  texture       String?
  pattern       String?       // Solid, Pinstripe, Check, etc.
  color         String?
  colorHex      String?
  image         String?
  images        String?       // JSON array
  pricePerMeter Float
  stockQuantity Float         @default(0)
  minOrder      Float         @default(1)
  origin        String?       // Country of origin
  quality       FabricQuality @default(STANDARD)
  isActive      Boolean       @default(true)
  isPremium     Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  productItems  ProductItem[]
  cartItems     CartItem[]

  @@map("fabrics")
}

enum FabricQuality {
  BUDGET
  STANDARD
  PREMIUM
  LUXURY
}

model Product {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  description   String?
  categoryId    String?
  productType   ProductType
  basePrice     Float
  isActive      Boolean       @default(true)
  isFeatured    Boolean       @default(false)
  isNew         Boolean       @default(false)
  images        String?       // JSON array of image URLs
  thumbnail     String?
  tags          String?       // JSON array
  seoTitle      String?
  seoDesc       String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  category      Category?     @relation(fields: [categoryId], references: [id])
  items         ProductItem[]
  reviews       Review[]
  cartItems     CartItem[]
  wishlists     Wishlist[]

  @@map("products")
}

enum ProductType {
  SUIT
  SHIRT
  TROUSERS
  BLAZER
  WAISTCOAT
  KAFTAN
  ACCESSORY
}

model ProductItem {
  id            String      @id @default(cuid())
  productId     String
  fabricId      String?
  sku           String      @unique
  color         String?
  size          String?
  priceModifier Float       @default(0)
  stockQuantity Int         @default(0)
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  fabric        Fabric?     @relation(fields: [fabricId], references: [id])
  orderItems    OrderItem[]
  cartItems     CartItem[]

  @@map("product_items")
}

// ============================================
// SHOPPING CART & WISHLIST
// ============================================

model CartItem {
  id            String       @id @default(cuid())
  userId        String
  productId     String
  productItemId String?
  fabricId      String?
  quantity      Int          @default(1)
  customization String?      // JSON for custom options
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  product       Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  productItem   ProductItem? @relation(fields: [productItemId], references: [id])
  fabric        Fabric?      @relation(fields: [fabricId], references: [id])

  @@map("cart_items")
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("wishlists")
}

// ============================================
// ORDERS
// ============================================

model Order {
  id                String        @id @default(cuid())
  orderNumber       String        @unique
  userId            String
  
  // Pricing
  subtotal          Float
  discount          Float         @default(0)
  tax               Float         @default(0)
  shippingCost      Float         @default(0)
  total             Float
  
  // Payment
  paymentStatus     PaymentStatus @default(PENDING)
  paymentMethod     PaymentMethod?
  paymentReference  String?
  paidAt            DateTime?
  
  // Delivery
  deliveryMethod    DeliveryMethod
  deliveryAddressId String?
  deliveryNotes     String?
  deliveryStatus    DeliveryStatus @default(PENDING)
  deliveredAt       DateTime?
  
  // Production
  productionStatus  ProductionStatus @default(PENDING)
  assignedTailorId  String?
  estimatedReady    DateTime?
  actualReady       DateTime?
  
  // Status
  status            OrderStatus   @default(PENDING)
  notes             String?
  cancelledAt       DateTime?
  cancelReason      String?
  
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user              User          @relation(fields: [userId], references: [id])
  items             OrderItem[]
  statusHistory     OrderStatusHistory[]

  @@map("orders")
}

model OrderItem {
  id              String    @id @default(cuid())
  orderId         String
  productItemId   String?
  
  // Snapshot at time of order
  productName     String
  productType     ProductType
  fabricName      String?
  quantity        Int
  unitPrice       Float
  totalPrice      Float
  
  // Customization
  customization   String?   // JSON
  measurementId   String?
  specialRequests String?
  
  // Production tracking
  productionNotes String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productItem     ProductItem?  @relation(fields: [productItemId], references: [id])

  @@map("order_items")
}

model OrderStatusHistory {
  id          String      @id @default(cuid())
  orderId     String
  status      OrderStatus
  notes       String?
  createdAt   DateTime    @default(now())

  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_status_history")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PRODUCTION
  READY
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  DEPOSIT_PAID
  PARTIALLY_PAID
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CARD
  MPESA
  TIGO_PESA
  AIRTEL_MONEY
  BANK_TRANSFER
  CASH
}

enum DeliveryMethod {
  PICKUP
  DELIVERY
}

enum DeliveryStatus {
  PENDING
  PROCESSING
  SHIPPED
  IN_TRANSIT
  DELIVERED
}

enum ProductionStatus {
  PENDING
  CUTTING
  SEWING
  FINISHING
  QUALITY_CHECK
  READY
}

// ============================================
// APPOINTMENTS & BOOKING
// ============================================

model Appointment {
  id            String          @id @default(cuid())
  userId        String
  staffId       String?
  
  type          AppointmentType
  scheduledAt   DateTime
  duration      Int             @default(60)  // minutes
  status        AppointmentStatus @default(PENDING)
  
  // Location
  location      String?
  addressId     String?
  isVirtual     Boolean         @default(false)
  meetingLink   String?
  
  // Details
  notes         String?
  reminderSent  Boolean         @default(false)
  
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  user          User            @relation(fields: [userId], references: [id])

  @@map("appointments")
}

enum AppointmentType {
  IN_STORE_FITTING
  VIRTUAL_CONSULTATION
  MEASUREMENT_SESSION
  STYLE_CONSULTATION
  PICKUP
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ============================================
// REVIEWS
// ============================================

model Review {
  id          String    @id @default(cuid())
  userId      String
  productId   String?
  orderId     String?
  
  rating      Int       // 1-5
  title       String?
  comment     String?
  images      String?   // JSON array
  
  isVerified  Boolean   @default(false)
  isPublished Boolean   @default(true)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id])
  product     Product?  @relation(fields: [productId], references: [id])

  @@map("reviews")
}

// ============================================
// PROMOTIONS & DISCOUNTS
// ============================================

model Promotion {
  id            String    @id @default(cuid())
  code          String    @unique
  name          String
  description   String?
  
  discountType  DiscountType
  discountValue Float
  minPurchase   Float?
  maxDiscount   Float?
  
  usageLimit    Int?
  usageCount    Int       @default(0)
  perUserLimit  Int       @default(1)
  
  startDate     DateTime
  endDate       DateTime
  isActive      Boolean   @default(true)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("promotions")
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id          String            @id @default(cuid())
  userId      String?
  type        NotificationType
  title       String
  message     String
  data        String?           // JSON
  isRead      Boolean           @default(false)
  readAt      DateTime?
  createdAt   DateTime         @default(now())

  @@map("notifications")
}

enum NotificationType {
  ORDER_UPDATE
  PAYMENT_RECEIVED
  APPOINTMENT_REMINDER
  PROMOTION
  SYSTEM
}

// ============================================
// SETTINGS & CONFIGURATION
// ============================================

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   // JSON value
  category  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}
